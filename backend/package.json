{
  "name": "sleep-api",
  "version": "2.7.1",
  "private": true,
  "main": "app.ts",
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "build": "tsc && tsc-alias && tsoa spec",
    "postbuild": "copyfiles -u 1 src/**/*.html src/**/*.css src/**/**/*.json src/**/*.png src/assets/* src/assets/**/* dist/",
    "start": "npm run build && node ./dist/app.js",
    "dev": "tsx watch --clear-screen --inspect src/app.ts",
    "frontend": "npm run postbuild && node dist/app.js",
    "test": "vitest --run --coverage",
    "test-watch": "vitest --changed"
  },
  "files": ["dist"],
  "exports": {
    ".": "./src/vitest/mocks/index.js"
  },
  "devDependencies": {
    "@types/cors": "^2.8.15",
    "@types/express": "^4.17.20",
    "@types/morgan": "^1.9.7",
    "@types/node": "^22.10.1",
    "@types/swagger-jsdoc": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.5",
    "@vitest/coverage-v8": "^1.6.0",
    "concurrently": "^8.2.2",
    "copyfiles": "^2.4.1",
    "nodemon": "^3.0.1",
    "rimraf": "^5.0.5",
    "sleepapi-common": "file:../common",
    "sqlite3": "^5.1.6",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vimic": "^1.0.7",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.11",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "google-auth-library": "^9.10.0",
    "knex": "^3.1.0",
    "morgan": "~1.9.1",
    "mysql2": "~3.9.7",
    "swagger-ui-express": "^5.0.0",
    "tsoa": "^6.6.0",
    "workerpool": "^9.1.3"
  },
  "bundleDependencies": ["sleepapi-common"]
}
